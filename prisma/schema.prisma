generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum Locale {
  id
  en
}

enum ArticleStatus {
  draft
  published
}

model Article {
  id           String             @id @default(cuid())
  category     String
  author       String
  image        String
  status       ArticleStatus      @default(draft)
  createdAt    DateTime           @default(now())
  publishedAt  DateTime?
  updatedAt    DateTime           @updatedAt
  translations ArticleTranslation[]
}

model ArticleTranslation {
  id        String   @id @default(cuid())
  articleId String
  locale    Locale
  title     String
  slug      String
  excerpt   String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, locale])
  @@unique([slug, locale])
  @@index([locale])
  @@index([articleId])
}

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
}

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  createdAt DateTime @default(now())
}
